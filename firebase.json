{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "node_modules/**",
      "*.config.js",
      "*.config.ts",
      "**/.*"
    ],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": ".firebase/tandaan-app/functions",
      "codebase": "tandaan-app-functions",
      "runtime": "node22"
    }
  ]
}